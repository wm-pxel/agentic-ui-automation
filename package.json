{
  "name": "agentic-ui-automation",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "agentic-ui": "./dist/src/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "dev": "tsx src/cli.ts",
    "dev:all": "tsx src/dev/runAll.ts",
    "viewer": "tsx src/cli.ts viewer",
    "desktop:dev": "npm run desktop:build && electron dist/src/desktop/main.js",
    "desktop:build": "npm run build && node scripts/copy-desktop-assets.mjs",
    "desktop:patient-flow": "tsx scripts/run-electron-patient-flow.mjs",
    "watch:intake": "tsx src/cli.ts watch --inbox ~/Downloads/agentic-ui-intake --runs-dir runs",
    "smoke:openmrs": "tsx src/cli.ts run --input data/demo/intake-records.json --targets openmrs --synthetic-suffix auto --openmrs-concurrency 1"
  },
  "dependencies": {
    "@playwright/test": "^1.46.0",
    "commander": "^12.1.0",
    "csv-parse": "^5.5.6",
    "jszip": "^3.10.1",
    "openai": "^4.56.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "electron": "^41.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
